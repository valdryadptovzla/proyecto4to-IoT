name: gestion-energetica

services:
  mongo:
    image: mongo:7
    container_name: gestion-energetica-mongo
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db

  backend:
    build:
      context: ./backend
    container_name: gestion-energetica-api
    depends_on:
      - mongo
    environment:
      MONGO_URL: mongodb://mongo:27017
      MONGO_DB_NAME: gestion_energetica
      ALLOWED_ORIGINS: "*"
    ports:
      - "8000:8000"

volumes:
  mongo_data:
